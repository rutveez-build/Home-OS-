# ─────────────────────────────────────────────────────────────
# Family OS — environment configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the keys you have.
# Anything you don't have a key for can stay empty — that
# capability will be disabled at runtime with a clear log line.
# ─────────────────────────────────────────────────────────────


# ── Brand (rebrand the whole product without touching components) ──
BRAND_NAME="Family OS"
BRAND_TAGLINE="Your family, on one chat."
BRAND_CITY="Bangalore"
BRAND_LANGUAGES="English, हिन्दी, ಕನ್ನಡ"

# ── Database (Postgres) ────────────────────────────────────
# Required. Local dev: docker run postgres, or use Neon/Railway/Supabase.
DATABASE_URL=postgresql://user:pass@localhost:5432/family_os
# Optional: separate URL for running migrations (e.g. public proxy).
DATABASE_URL_MIGRATIONS=

# ── LLM provider (pick one) ────────────────────────────────
# Any OpenAI-compatible API works. Defaults below assume Moonshot (Kimi).
# To use OpenAI / Anthropic / Mistral / etc., change BASE_URL + MODEL.
LLM_API_KEY=
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_MODEL=kimi-latest
# Optional second model for "deep / reasoning" mode (e.g. kimi-k2.5, o1)
LLM_MODEL_DEEP=kimi-k2.5

# ── WhatsApp provider (pick one) ───────────────────────────
# 'meta_cloud' — direct from Meta. Free hosting, cheapest. Recommended.
# 'twilio'     — Twilio Sandbox or paid. Easier for prototypes.
# 'none'       — disabled (chat works on web only).
WHATSAPP_PROVIDER=none

# Meta Cloud API (when WHATSAPP_PROVIDER=meta_cloud)
META_WABA_ID=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=set-a-random-string-here
META_APP_SECRET=

# Twilio (when WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── ASR (voice-note transcription) ─────────────────────────
# 'sarvam'  — Indic-optimized, recommended for India.
# 'whisper' — OpenAI Whisper, English-strong.
# 'none'    — voice notes will be skipped.
ASR_PROVIDER=none
SARVAM_API_KEY=
OPENAI_API_KEY=    # used for Whisper

# ── Vision (lab reports, prescriptions, photos) ────────────
# 'kimi'   — Moonshot vision model.
# 'openai' — gpt-4o-mini.
# 'none'   — image attachments will be ignored.
VISION_PROVIDER=none
VISION_API_KEY=    # falls back to LLM_API_KEY if blank
VISION_BASE_URL=
VISION_MODEL=moonshot-v1-128k-vision-preview

# ── Behaviour ──────────────────────────────────────────────
# Tweak the assistant's persona without code changes.
SYSTEM_PROMPT_OVERRIDE=
# Misc
NEXT_TELEMETRY_DISABLED=1
